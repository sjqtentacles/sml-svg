(* MLB for the sml-svg library: the vendored sml-pretty printer plus the SVG
 * sources. Consumers reference this file.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that
 * consumers (the test suite, examples) can `open Pretty` alongside Svg. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-pretty/sources.mlb
svg.sig
svg.sml
